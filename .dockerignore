# secrets — must never enter the image
.env
.env.*
*.pem
*.key

# large local-only data directories
tmp/
data/cloned/
data/training_data.json
data/pr_curve.png
data/graph.json

# Python cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# frontend (served separately, not part of the API image)
src/frontend/node_modules/
src/frontend/dist/

# git / editor
.git/
.gitignore
.vscode/
.idea/

# dev / CI artefacts
*.log
analysis_comment.md
devlog.md
